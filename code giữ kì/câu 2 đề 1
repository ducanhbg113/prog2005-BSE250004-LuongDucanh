def songuyento(n):
    if n < 2:
        return False
    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    return True
print("Các số nguyên tố từ 17 đến 111:")
for i in range(17, 112):
    if songuyento(i):
        print(i, end=" ")